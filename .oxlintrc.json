{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/no-unknown-property": "off",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": ["dist", ".astro", "node_modules", "src/components/ui"]
}
