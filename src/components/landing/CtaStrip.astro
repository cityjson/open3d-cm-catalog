---
import { ghUrl } from "@/lib/site";
---

<section
  style="border-top:1px solid rgba(255,255,255,.06); padding:80px 56px; text-align:center; position:relative; background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px); background-size:48px 48px;"
>
  <h2
    style="margin:0 0 16px; font-size:38px; line-height:1.1; letter-spacing:-.02em; font-weight:700; text-wrap:balance;"
  >
    Put your city on the map.
  </h2>
  <p style="margin:0 auto 32px; font-size:18px; color:#9fb2bd; max-width:34em;">
    Help build the first uniform, open registry of the world's 3D city models.
  </p>
  <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
    <a
      href="#contribute"
      style="display:inline-flex; align-items:center; gap:9px; background:#00a6d6; color:#03121b; font-weight:600; font-size:15.5px; padding:14px 26px; border-radius:4px; text-decoration:none;"
      >Contribute a dataset</a
    >
    <a
      href={ghUrl}
      target="_blank"
      rel="noreferrer"
      style="display:inline-flex; align-items:center; gap:9px; border:1px solid rgba(255,255,255,.2); color:#eaf1f5; font-weight:500; font-size:15.5px; padding:14px 26px; border-radius:4px; text-decoration:none;"
      >Browse the registry</a
    >
  </div>
</section>
