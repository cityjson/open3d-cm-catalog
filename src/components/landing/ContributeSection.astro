---
import { ghUrl } from "@/lib/site";
import { CopyCommand } from "./CopyCommand";

const steps = [
  {
    n: 1,
    title: "Fork the registry",
    body: 'Clone <span style="font-family:\'Geist Mono Variable\',monospace; color:#34c3f0;">city3d-stac-registry</span> on GitHub.',
  },
  {
    n: 2,
    title: "Describe your dataset",
    body: "Write a STAC item using the 3D city model extension fields.",
  },
  {
    n: 3,
    title: "Validate & open a PR",
    body: "CI checks the schema automatically. Maintainers review.",
  },
  {
    n: 4,
    title: "Merged & on the map",
    body: "Your dataset joins the registry and shows up in the map.",
  },
];
---

<section id="contribute" style="padding:96px 56px; border-top:1px solid rgba(255,255,255,.06);">
  <div style="max-width:1280px; margin:0 auto;">
    <div
      style="font-family:'Geist Mono Variable',monospace; font-size:12.5px; letter-spacing:.18em; text-transform:uppercase; color:#7e96a3; margin-bottom:18px;"
    >
      04 — Contribute
    </div>
    <h2
      style="margin:0 0 18px; font-size:40px; line-height:1.1; letter-spacing:-.02em; font-weight:700; max-width:16em; text-wrap:balance;"
    >
      Add your dataset with a pull request.
    </h2>
    <p style="margin:0 0 56px; font-size:18px; line-height:1.55; color:#9fb2bd; max-width:42em;">
      The registry is open. No gatekeeping — describe your model as a STAC item, open a PR, and once
      it's merged it appears on the map for everyone.
    </p>
    <div
      class="o3d-contribute-grid"
      style="display:grid; grid-template-columns:1.1fr .9fr; gap:48px; align-items:start;"
    >
      <div style="display:flex; flex-direction:column; gap:0;">
        {
          steps.map((step, i) => (
            <div
              style={`display:flex; gap:20px; ${i < steps.length - 1 ? "padding-bottom:28px; " : ""}border-left:1px solid rgba(0,166,214,.3); padding-left:28px; position:relative; margin-left:14px;`}
            >
              <div style="position:absolute; left:-14px; top:0; width:28px;height:28px; border-radius:50%; background:#00a6d6; color:#03121b; font-family:'Geist Mono Variable',monospace; font-weight:600; font-size:13px; display:flex; align-items:center; justify-content:center;">
                {step.n}
              </div>
              <div>
                <div style="font-size:17px; font-weight:600; margin-bottom:5px;">{step.title}</div>
                <p
                  style="margin:0; font-size:14.5px; line-height:1.55; color:#8aa2b0;"
                  set:html={step.body}
                />
              </div>
            </div>
          ))
        }
      </div>
      <div>
        <div style="background:#0c1d29; border:1px solid rgba(255,255,255,.1); border-radius:7px; overflow:hidden;">
          <div
            style="display:flex; align-items:center; justify-content:space-between; padding:11px 15px; border-bottom:1px solid rgba(255,255,255,.08);"
          >
            <span style="font-family:'Geist Mono Variable',monospace; font-size:11.5px; color:#6f8794;">terminal</span>
            <CopyCommand client:visible />
          </div>
          <pre
            style="margin:0; padding:18px 16px; font-family:'Geist Mono Variable',monospace; font-size:12.5px; line-height:1.9; color:#9fb2bd; white-space:pre-wrap;"><span style="color:#5f7886;"># clone the registry</span>
<span style="color:#00a6d6;">git</span> clone city3d-stac-registry

<span style="color:#5f7886;"># validate your item</span>
<span style="color:#00a6d6;">stac-validator</span> delft.json

<span style="color:#5f7886;"># open a pull request</span>
<span style="color:#00a6d6;">gh</span> pr create</pre>
        </div>
        <a
          href={ghUrl}
          target="_blank"
          rel="noreferrer"
          style="display:flex; align-items:center; justify-content:center; gap:9px; margin-top:18px; background:#00a6d6; color:#03121b; font-weight:600; font-size:15.5px; padding:14px; border-radius:4px; text-decoration:none;"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9v2.81c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
            ></path></svg
          >
          Open the registry on GitHub
        </a>
      </div>
    </div>
  </div>
</section>
