---
import { ghUrl } from "@/lib/site";
---

<section
  style="position:relative; background-image:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px); background-size:56px 56px; overflow:hidden;"
>
  <div
    style="position:absolute; top:-200px; right:-140px; width:680px; height:680px; background:radial-gradient(circle, rgba(0,166,214,.20), transparent 68%); pointer-events:none;"
  >
  </div>
  <div
    class="o3d-hero-grid"
    style="position:relative; max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 500px; gap:64px; padding:96px 56px 104px; align-items:center;"
  >
    <div>
      <div
        style="font-family:'Geist Mono Variable',monospace; font-size:13px; letter-spacing:.18em; text-transform:uppercase; color:#00a6d6; margin-bottom:24px;"
      >
        STAC extension · CityJSON · CityGML
      </div>
      <h1
        style="margin:0 0 24px; font-size:64px; line-height:1.02; letter-spacing:-.03em; font-weight:700; text-wrap:balance;"
      >
        The open registry for the world's 3D city models.
      </h1>
      <p
        style="margin:0 0 36px; font-size:19px; line-height:1.55; color:#9fb2bd; max-width:32em;"
      >
        One standard schema. One curated list. One map. Describe any CityJSON or CityGML dataset as
        a STAC item — and make it discoverable, comparable, and contributable by everyone.
      </p>
      <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
        <a
          href="#contribute"
          style="display:inline-flex; align-items:center; gap:9px; background:#00a6d6; color:#03121b; font-weight:600; font-size:15.5px; padding:14px 24px; border-radius:4px; text-decoration:none;"
          >Contribute a dataset
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
          >
        </a>
        <a
          href={ghUrl}
          target="_blank"
          rel="noreferrer"
          style="display:inline-flex; align-items:center; gap:9px; border:1px solid rgba(255,255,255,.2); color:#eaf1f5; font-weight:500; font-size:15.5px; padding:14px 24px; border-radius:4px; text-decoration:none;"
          >Browse the registry</a
        >
      </div>
      <div
        style="display:flex; gap:10px; margin-top:38px; font-family:'Geist Mono Variable',monospace; font-size:12.5px; flex-wrap:wrap;"
      >
        <span style="padding:7px 12px; border:1px solid rgba(255,255,255,.12); border-radius:3px; color:#9fb2bd;">CityJSON</span>
        <span style="padding:7px 12px; border:1px solid rgba(255,255,255,.12); border-radius:3px; color:#9fb2bd;">CityGML</span>
        <span style="padding:7px 12px; border:1px solid rgba(255,255,255,.12); border-radius:3px; color:#9fb2bd;">FlatCityBuf</span>
        <span style="padding:7px 12px; border:1px solid rgba(255,255,255,.12); border-radius:3px; color:#9fb2bd;">Machine-readable</span>
      </div>
    </div>
    <div
      style="background:#0c1d29; border:1px solid rgba(255,255,255,.1); border-radius:7px; overflow:hidden; box-shadow:0 24px 60px rgba(0,0,0,.4);"
    >
      <div
        style="display:flex; align-items:center; gap:8px; padding:12px 15px; border-bottom:1px solid rgba(255,255,255,.08);"
      >
        <span style="width:10px;height:10px;border-radius:50%;background:#26404f;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#26404f;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#26404f;"></span>
        <span style="margin-left:8px; font-family:'Geist Mono Variable',monospace; font-size:12px; color:#6f8794;">9-284-556.city.json</span>
      </div>
      <pre
        style="margin:0; padding:20px 18px; font-family:'Geist Mono Variable',monospace; font-size:12.5px; line-height:1.8; color:#9fb2bd; white-space:pre; overflow:auto;">{'{'}
  <span style="color:#00a6d6;">"type"</span>: <span style="color:#cfe6ef;">"Feature"</span>,
  <span style="color:#00a6d6;">"stac_version"</span>: <span style="color:#cfe6ef;">"1.1.0"</span>,
  <span style="color:#00a6d6;">"stac_extensions"</span>: [
    <span style="color:#cfe6ef;">"https://cityjson.github.io/stac-city3d/v0.2.0/schema.json"</span>,
    <span style="color:#cfe6ef;">"https://stac-extensions.github.io/projection/v2.0.0/schema.json"</span>
  ],
  <span style="color:#00a6d6;">"id"</span>: <span style="color:#cfe6ef;">"9-284-556.city.json"</span>,
  <span style="color:#00a6d6;">"collection"</span>: <span style="color:#cfe6ef;">"netherlands-3d-bag"</span>,
  <span style="color:#00a6d6;">"assets"</span>: {'{'}
    <span style="color:#00a6d6;">"data"</span>: {'{'}
      <span style="color:#00a6d6;">"href"</span>: <span style="color:#cfe6ef;">"https://data.3dbag.nl/v20250903/tiles/9/284/556/9-284-556.city.json.gz"</span>,
      <span style="color:#00a6d6;">"type"</span>: <span style="color:#cfe6ef;">"application/city+json"</span>,
      <span style="color:#00a6d6;">"roles"</span>: [<span style="color:#cfe6ef;">"data"</span>]
    {'}'}
  {'}'},
  <span style="color:#00a6d6;">"properties"</span>: {'{'}
    <span style="color:#00a6d6;">"proj:code"</span>: <span style="color:#cfe6ef;">"EPSG:7415"</span>,
    <span style="color:#00a6d6;">"city3d:version"</span>: <span style="color:#cfe6ef;">"2.0"</span>,
    <span style="color:#00a6d6;">"city3d:lods"</span>: [<span style="color:#cfe6ef;">"0"</span>, <span style="color:#cfe6ef;">"1.2"</span>, <span style="color:#cfe6ef;">"1.3"</span>, <span style="color:#cfe6ef;">"2.2"</span>],
    <span style="color:#00a6d6;">"city3d:co_types"</span>: [<span style="color:#cfe6ef;">"Building"</span>, <span style="color:#cfe6ef;">"BuildingPart"</span>],
    <span style="color:#00a6d6;">"city3d:city_objects"</span>: <span style="color:#e5b33a;">2423</span>,
    <span style="color:#00a6d6;">"city3d:materials"</span>: <span style="color:#e5b33a;">false</span>
  {'}'}
{'}'}<span style="display:inline-block; width:8px; height:16px; background:#00a6d6; vertical-align:-2px; margin-left:2px; animation:o3d-blink 1.1s steps(1) infinite;"></span></pre>
    </div>
  </div>
</section>
