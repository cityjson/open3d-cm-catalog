---
const CATALOG_URL = "https://storage.googleapis.com/city3d-stac/catalog.json";
---

<section style="padding:96px 56px; border-top:1px solid rgba(255,255,255,.06);">
  <div
    class="o3d-ai-grid"
    style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center;"
  >
    <div>
      <div
        style="font-family:'Geist Mono Variable',monospace; font-size:12.5px; letter-spacing:.18em; text-transform:uppercase; color:#7e96a3; margin-bottom:18px;"
      >
        For AI agents
      </div>
      <h2
        style="margin:0 0 22px; font-size:40px; line-height:1.1; letter-spacing:-.02em; font-weight:700; text-wrap:balance;"
      >
        Made for the age of AI agents.
      </h2>
      <p style="margin:0 0 20px; font-size:17px; line-height:1.6; color:#9fb2bd;">
        STAC is plain, linked JSON — exactly the shape today's LLM agents parse well. There's no
        scraping and no bespoke API: point an agent at the root catalog and it can crawl collections
        and items to discover <b style="color:#cfe6ef; font-weight:600;">what 3D city data exists,
        where it is, and at which level of detail</b>.
      </p>
      <p style="margin:0; font-size:17px; line-height:1.6; color:#9fb2bd;">
        Hand your assistant the endpoint and ask it what's available.
      </p>
    </div>
    <div
      style="background:#0c1d29; border:1px solid rgba(255,255,255,.1); border-radius:7px; overflow:hidden; box-shadow:0 24px 60px rgba(0,0,0,.4);"
    >
      <div
        style="display:flex; align-items:center; gap:8px; padding:12px 15px; border-bottom:1px solid rgba(255,255,255,.08);"
      >
        <span
          style="width:8px;height:8px;border-radius:50%;background:#00a6d6;box-shadow:0 0 0 4px rgba(0,166,214,.16);"
        ></span>
        <span style="font-family:'Geist Mono Variable',monospace; font-size:12px; color:#6f8794;"
          >catalog endpoint</span
        >
      </div>
      <div style="padding:20px 18px;">
        <div
          style="font-family:'Geist Mono Variable',monospace; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:#7e96a3; margin-bottom:10px;"
        >
          GET
        </div>
        <a
          href={CATALOG_URL}
          target="_blank"
          rel="noreferrer"
          style="font-family:'Geist Mono Variable',monospace; font-size:13.5px; line-height:1.6; color:#34c3f0; text-decoration:none; word-break:break-all;"
          >{CATALOG_URL}</a
        >
        <p style="margin:18px 0 0; font-size:13.5px; line-height:1.6; color:#7e96a3;">
          The root <span style="color:#9fb2bd;">Catalog</span> links to every
          <span style="color:#9fb2bd;">Collection</span> and <span style="color:#9fb2bd;">Item</span>
          — follow the links to walk the whole registry.
        </p>
      </div>
    </div>
  </div>
</section>
