---
import { asset, ghUrl } from "@/lib/site";
---

<nav
  style="position:sticky; top:0; z-index:20; display:flex; align-items:center; justify-content:space-between; padding:18px 56px; background:rgba(10,22,32,.86); backdrop-filter:blur(8px); border-bottom:1px solid rgba(255,255,255,.07);"
>
  <div style="display:flex; align-items:center; gap:11px;">
    <img
      src={asset("assets/logo-type.svg")}
      alt="Open3D"
      style="height:26px; width:auto; display:block;"
    />
    <span style="font-size:16px; font-weight:400; letter-spacing:-.01em; color:#7e96a3;"
      >City Model Catalog</span
    >
    <span
      style="font-family:'Geist Mono Variable',monospace; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#e5b33a; padding:3px 8px; border:1px solid rgba(229,179,58,.4); border-radius:999px; background:rgba(229,179,58,.08);"
      >Beta</span
    >
  </div>
  <div style="display:flex; align-items:center; gap:30px; font-size:14.5px; color:#9fb2bd;">
    <span class="o3d-nav-anchors" style="display:flex; align-items:center; gap:30px;">
      <a href="#problem" style="color:inherit; text-decoration:none;">Problem</a>
      <a href="#stac" style="color:inherit; text-decoration:none;">STAC</a>
      <a href="#map" style="color:inherit; text-decoration:none;">Map</a>
      <a href="#contribute" style="color:inherit; text-decoration:none;">Contribute</a>
    </span>
    <a
      href={ghUrl}
      target="_blank"
      rel="noreferrer"
      style="display:inline-flex; align-items:center; gap:8px; padding:9px 16px; border:1px solid rgba(255,255,255,.16); border-radius:4px; color:#eaf1f5; text-decoration:none;"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9v2.81c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
        ></path>
      </svg>
      GitHub
    </a>
  </div>
</nav>
