<section id="stac" style="padding:96px 56px; border-top:1px solid rgba(255,255,255,.06);">
  <div
    class="o3d-stac-grid"
    style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1.05fr .95fr; gap:72px; align-items:center;"
  >
    <div>
      <div
        style="font-family:'Geist Mono Variable',monospace; font-size:12.5px; letter-spacing:.18em; text-transform:uppercase; color:#7e96a3; margin-bottom:18px;"
      >
        02 — The standard
      </div>
      <h2
        style="margin:0 0 22px; font-size:40px; line-height:1.1; letter-spacing:-.02em; font-weight:700; text-wrap:balance;"
      >
        STAC, extended for 3D city models.
      </h2>
      <p style="margin:0 0 20px; font-size:17px; line-height:1.6; color:#9fb2bd;">
        <b style="color:#cfe6ef; font-weight:600;">STAC</b> — the SpatioTemporal Asset Catalog — is a
        widely-adopted JSON standard for describing geospatial assets so they're searchable and
        machine-readable.
      </p>
      <p style="margin:0 0 28px; font-size:17px; line-height:1.6; color:#9fb2bd;">
        Our <b style="color:#cfe6ef; font-weight:600;">3D city model extension</b> adds the fields that
        matter for CityJSON and CityGML: version, levels of detail, CRS, and city-object types — so every
        dataset fits the same shape and can be queried, compared and mapped.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:30px;">
        {
          ["city3d:version", "city3d:lods", "city3d:co_types", "city3d:city_objects", "proj:code"].map((field) => (
            <span style="font-family:'Geist Mono Variable',monospace; font-size:12px; padding:6px 11px; background:rgba(0,166,214,.1); border:1px solid rgba(0,166,214,.3); border-radius:3px; color:#34c3f0;">
              {field}
            </span>
          ))
        }
      </div>
      <div
        style="display:inline-flex; align-items:center; gap:9px; color:#9fb2bd; font-size:15px;"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7e96a3" stroke-width="2"
          ><path d="M12 8v4M12 16h.01M12 3l9 16H3L12 3Z"></path></svg
        >
        The research paper is under review.
      </div>
    </div>
    <div style="display:flex; flex-direction:column; gap:0; position:relative; padding-left:22px;">
      <div style="position:absolute; left:0; top:28px; bottom:28px; width:1px; background:rgba(0,166,214,.4);"></div>
      <div style="position:relative; margin-bottom:16px;">
        <div style="position:absolute; left:-22px; top:22px; width:22px; height:1px; background:rgba(0,166,214,.4);"></div>
        <div style="border:1px solid rgba(0,166,214,.4); background:rgba(0,166,214,.06); border-radius:6px; padding:16px 18px;">
          <div style="font-family:'Geist Mono Variable',monospace; font-size:11px; color:#00a6d6; letter-spacing:.1em;">CATALOG</div>
          <div style="font-size:15px; color:#cfe6ef; margin-top:3px; font-weight:500;">Open 3D City Models</div>
          <div style="font-size:13px; color:#7e96a3; margin-top:2px;">The root of the registry</div>
        </div>
      </div>
      <div style="position:relative; margin-bottom:16px; margin-left:30px;">
        <div style="position:absolute; left:-30px; top:22px; width:30px; height:1px; background:rgba(0,166,214,.32);"></div>
        <div style="border:1px solid rgba(255,255,255,.14); background:#0c1d29; border-radius:6px; padding:16px 18px;">
          <div style="font-family:'Geist Mono Variable',monospace; font-size:11px; color:#7e96a3; letter-spacing:.1em;">COLLECTION</div>
          <div style="font-size:15px; color:#cfe6ef; margin-top:3px; font-weight:500;">Netherlands · 3D BAG</div>
          <div style="font-size:13px; color:#7e96a3; margin-top:2px;">A grouping by region or provider</div>
        </div>
      </div>
      <div style="position:relative; margin-left:60px;">
        <div style="position:absolute; left:-60px; top:22px; width:60px; height:1px; background:rgba(0,166,214,.26);"></div>
        <div style="border:1px solid rgba(255,255,255,.12); background:#0c1d29; border-radius:6px; padding:16px 18px;">
          <div style="font-family:'Geist Mono Variable',monospace; font-size:11px; color:#7e96a3; letter-spacing:.1em;">ITEM · 3D extension</div>
          <div style="font-size:15px; color:#cfe6ef; margin-top:3px; font-weight:500;">delft.city.jsonl</div>
          <div style="font-size:13px; color:#7e96a3; margin-top:2px;">A single dataset — LoD 2.2 · EPSG:28992</div>
        </div>
      </div>
    </div>
  </div>
</section>
